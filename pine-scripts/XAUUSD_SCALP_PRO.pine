//@version=6
// ============================================================
// ATLAS PRO — XAUUSD Scalping Strategy v4 "KILLSHOT"
// Fixes vs v3:
//   • Backtest now works on TVC:GOLD (volume is na there — handled)
//   • Anti-SL-hunt: stop placed BEYOND the hunt zone (wick extreme
//     of last N bars + deep ATR buffer), not at the obvious swing
//   • Partial exit: 50% off at +1R then SL → breakeven.
//     A hunt-then-target move now ends GREEN or FLAT, never red.
//   • Exits issued with frozen levels at entry — tester-accurate
// Timeframe : 5m or 15m | Asset: XAUUSD / TVC:GOLD / OANDA:XAUUSD
// ============================================================
strategy("ATLAS PRO · XAUUSD Killshot v4", shorttitle="ATLAS·GOLD·v4",
  overlay=true, pyramiding=0,
  default_qty_type=strategy.percent_of_equity, default_qty_value=2,
  initial_capital=10000, commission_type=strategy.commission.percent,
  commission_value=0.02, slippage=2,
  calc_on_every_tick=false, process_orders_on_close=true)

// ── Inputs ───────────────────────────────────────────────────
grp1 = "Trend Engine"
emaFastLen = input.int(9,  "Fast EMA", group=grp1)
emaMidLen  = input.int(21, "Pullback EMA", group=grp1)
emaSlowLen = input.int(50, "Slow EMA", group=grp1)
htfTF      = input.timeframe("60", "HTF Trend Timeframe", group=grp1)
htfEmaLen  = input.int(50, "HTF EMA Length", group=grp1)

grp2 = "Regime Filter (anti-chop)"
adxLen = input.int(14, "ADX Length", group=grp2)
adxMin = input.float(22, "Min ADX to trade", step=1, group=grp2)

grp3 = "Liquidity Sweep"
useSweep  = input.bool(true, "Trade liquidity sweeps", group=grp3)
sweepLook = input.int(20, "Swing lookback (bars)", group=grp3)
wickRatio = input.float(0.5, "Min wick ratio", step=0.05, group=grp3)

grp4 = "Risk (anti-SL-hunt)"
atrLen     = input.int(14, "ATR Length", group=grp4)
huntBars   = input.int(8,  "Stop beyond extreme of last N bars", group=grp4)
slBuf      = input.float(0.75, "Extra SL buffer × ATR", step=0.05, group=grp4)
tp1R       = input.float(1.0, "TP1 at +R (take 50%)", step=0.25, group=grp4)
tp2R       = input.float(2.0, "TP2 at +R (runner)",   step=0.25, group=grp4)

grp5 = "Filters"
rsiLen  = input.int(14, "RSI Length", group=grp5)
useSess = input.bool(true, "London + NY only", group=grp5)
useVol  = input.bool(true, "Volume confirmation (auto-skips if feed has no volume)", group=grp5)
volMult = input.float(1.1, "Volume × avg", step=0.1, group=grp5)
maxSpreadAtr = input.float(2.5, "Skip news candles > × ATR", step=0.25, group=grp5)

// ── Indicators ───────────────────────────────────────────────
emaF  = ta.ema(close, emaFastLen)
emaM  = ta.ema(close, emaMidLen)
emaS  = ta.ema(close, emaSlowLen)
atr   = ta.atr(atrLen)
rsi   = ta.rsi(close, rsiLen)
vol20 = ta.sma(volume, 20)

htfEma   = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfEmaLen)[1], barmerge.gaps_off, barmerge.lookahead_on)
htfClose = request.security(syminfo.tickerid, htfTF, close[1], barmerge.gaps_off, barmerge.lookahead_on)
htfBull  = htfClose > htfEma
htfBear  = htfClose < htfEma

[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
trending = adxVal >= adxMin

londonSess = time(timeframe.period, "0700-1600", "UTC")
nySess     = time(timeframe.period, "1300-2100", "UTC")
inSession  = not useSess or (not na(londonSess) or not na(nySess))

// CRITICAL FIX: TVC:GOLD has no volume → na blocked all entries.
// If the feed has no volume, the filter auto-passes.
hasVolume = not na(volume) and not na(vol20) and vol20 > 0
volOK     = not useVol or not hasVolume or volume > vol20 * volMult
rangeOK   = (high - low) < atr * maxSpreadAtr

bullStack = emaF > emaM and emaM > emaS and close > emaS
bearStack = emaF < emaM and emaM < emaS and close < emaS

// ── SETUP A: Pullback continuation ───────────────────────────
touchedEmaM_L = low <= emaM and close > emaM
reclaimBull   = close > open and close > emaF
pullbackLong  = bullStack and htfBull and trending and touchedEmaM_L and reclaimBull and rsi > 45 and rsi < 70

touchedEmaM_S = high >= emaM and close < emaM
reclaimBear   = close < open and close < emaF
pullbackShort = bearStack and htfBear and trending and touchedEmaM_S and reclaimBear and rsi < 55 and rsi > 30

// ── SETUP B: Liquidity sweep reversal ────────────────────────
swingLow  = ta.lowest(low[1], sweepLook)
swingHigh = ta.highest(high[1], sweepLook)
candleRange = high - low
lowerWick = math.min(open, close) - low
upperWick = high - math.max(open, close)

sweepLong  = useSweep and htfBull and low < swingLow  and close > swingLow  and candleRange > 0 and (lowerWick / candleRange) >= wickRatio and close > open and rsi < 60
sweepShort = useSweep and htfBear and high > swingHigh and close < swingHigh and candleRange > 0 and (upperWick / candleRange) >= wickRatio and close < open and rsi > 40

// ── Signals ──────────────────────────────────────────────────
longSignal  = (pullbackLong or sweepLong)  and inSession and volOK and rangeOK and strategy.position_size == 0
shortSignal = (pullbackShort or sweepShort) and inSession and volOK and rangeOK and strategy.position_size == 0

// ── ANTI-HUNT STOPS ──────────────────────────────────────────
// Stop goes beyond the wick extreme of the last `huntBars` bars
// PLUS a deep ATR buffer — past the zone where stops get run.
longSLcalc  = ta.lowest(low, huntBars)  - atr * slBuf
shortSLcalc = ta.highest(high, huntBars) + atr * slBuf

longRisk  = close - longSLcalc
shortRisk = shortSLcalc - close

// ── Execution: freeze levels at entry, split exits ───────────
var float entryPx = na
var float slPx    = na
var float tp1Px   = na
var float tp2Px   = na
var bool  beMoved = false

if longSignal and longRisk > atr * 0.3   // skip degenerate tiny-risk signals
    entryPx := close
    slPx    := longSLcalc
    tp1Px   := close + longRisk * tp1R
    tp2Px   := close + longRisk * tp2R
    beMoved := false
    strategy.entry("LONG", strategy.long)
    setupName = sweepLong ? "Liquidity Sweep Reversal" : "Trend Pullback EMA21"
    alertMsg = '{"symbol":"XAUUSD","action":"BUY","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(slPx, "#.##") + ',"tp":' + str.tostring(tp2Px, "#.##") + ',"reason":"' + setupName + ' | TP1 ' + str.tostring(tp1Px, "#.##") + ' (50%) | HTF Bull | ADX ' + str.tostring(math.round(adxVal, 1)) + '","strategy":"GOLD_KILLSHOT_v4","interval":"' + timeframe.period + '"}'
    alert(alertMsg, alert.freq_once_per_bar_close)

if shortSignal and shortRisk > atr * 0.3
    entryPx := close
    slPx    := shortSLcalc
    tp1Px   := close - shortRisk * tp1R
    tp2Px   := close - shortRisk * tp2R
    beMoved := false
    strategy.entry("SHORT", strategy.short)
    setupName = sweepShort ? "Liquidity Sweep Reversal" : "Trend Pullback EMA21"
    alertMsg = '{"symbol":"XAUUSD","action":"SELL","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(slPx, "#.##") + ',"tp":' + str.tostring(tp2Px, "#.##") + ',"reason":"' + setupName + ' | TP1 ' + str.tostring(tp1Px, "#.##") + ' (50%) | HTF Bear | ADX ' + str.tostring(math.round(adxVal, 1)) + '","strategy":"GOLD_KILLSHOT_v4","interval":"' + timeframe.period + '"}'
    alert(alertMsg, alert.freq_once_per_bar_close)

// After TP1 fills (position halved) → SL to breakeven.
// Even if price then gets hunted back, worst case = breakeven runner + banked TP1.
if strategy.position_size != 0 and not beMoved
    if math.abs(strategy.position_size) < math.abs(strategy.position_size[1])
        slPx    := entryPx
        beMoved := true

// Exits: TP1 takes 50%, TP2 takes the rest; shared stop trails to BE
if strategy.position_size > 0
    strategy.exit("L_TP1", "LONG", qty_percent=50,  stop=slPx, limit=tp1Px)
    strategy.exit("L_TP2", "LONG", qty_percent=100, stop=slPx, limit=tp2Px)
if strategy.position_size < 0
    strategy.exit("S_TP1", "SHORT", qty_percent=50,  stop=slPx, limit=tp1Px)
    strategy.exit("S_TP2", "SHORT", qty_percent=100, stop=slPx, limit=tp2Px)

// ── Visuals ──────────────────────────────────────────────────
plot(emaF, "EMA 9",  color=color.new(color.lime,   30), linewidth=1)
plot(emaM, "EMA 21", color=color.new(color.yellow, 10), linewidth=2)
plot(emaS, "EMA 50", color=color.new(color.orange, 10), linewidth=2)

plotshape(pullbackLong  and longSignal,  "PB BUY",   shape.labelup,   location.belowbar, color.lime,   text="BUY",        textcolor=color.black, size=size.small)
plotshape(sweepLong     and longSignal,  "SWP BUY",  shape.labelup,   location.belowbar, color.aqua,   text="SWEEP\nBUY", textcolor=color.black, size=size.small)
plotshape(pullbackShort and shortSignal, "PB SELL",  shape.labeldown, location.abovebar, color.red,    text="SELL",       textcolor=color.white, size=size.small)
plotshape(sweepShort    and shortSignal, "SWP SELL", shape.labeldown, location.abovebar, color.orange, text="SWEEP\nSELL",textcolor=color.white, size=size.small)

if (longSignal and longRisk > atr * 0.3) or (shortSignal and shortRisk > atr * 0.3)
    line.new(bar_index, slPx,  bar_index + 10, slPx,  color=color.red,    width=2, style=line.style_dashed)
    line.new(bar_index, tp1Px, bar_index + 10, tp1Px, color=color.yellow, width=1, style=line.style_dotted)
    line.new(bar_index, tp2Px, bar_index + 10, tp2Px, color=color.lime,   width=2, style=line.style_dashed)
    label.new(bar_index + 10, slPx,  "SL "  + str.tostring(slPx,  "#.##"), style=label.style_label_left, color=color.new(color.red,    20), textcolor=color.white, size=size.small)
    label.new(bar_index + 10, tp1Px, "TP1 " + str.tostring(tp1Px, "#.##"), style=label.style_label_left, color=color.new(color.olive,  20), textcolor=color.white, size=size.small)
    label.new(bar_index + 10, tp2Px, "TP2 " + str.tostring(tp2Px, "#.##"), style=label.style_label_left, color=color.new(color.green,  20), textcolor=color.white, size=size.small)

bgcolor(trending and htfBull and bullStack ? color.new(color.lime, 94) :
        trending and htfBear and bearStack ? color.new(color.red,  94) :
        not trending ? color.new(color.gray, 96) : na, title="Regime")
