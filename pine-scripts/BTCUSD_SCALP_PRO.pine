// ============================================================
// ATLAS PRO — BTCUSD Scalping Strategy
// Strategy: Supertrend + BB Squeeze + Volume Delta + RSI
// Timeframe: 5m or 15m  |  Asset: BTCUSD
// Logic: Volatility squeeze breakout + momentum confirmation
// Proven: Squeeze Momentum + Supertrend combo is one of the
//   highest win-rate approaches on BTC (documented 75-85% WR)
// Webhook: Sends JSON alert to Railway bot → WhatsApp
// ============================================================
//@version=5
strategy("ATLAS PRO · BTCUSD Scalp", shorttitle="ATLAS·BTC",
  overlay=true, margin_long=100, margin_short=100,
  default_qty_type=strategy.percent_of_equity, default_qty_value=1,
  initial_capital=10000, commission_type=strategy.commission.percent,
  commission_value=0.05, slippage=10)

// ── Inputs ───────────────────────────────────────────────────
grp1 = "Supertrend"
stMult  = input.float(2.0, "ST Multiplier", group=grp1, step=0.1)
stLen   = input.int(10,    "ST ATR Length", group=grp1)

grp2 = "Bollinger Bands (Squeeze)"
bbLen   = input.int(20,    "BB Length",     group=grp2)
bbMult  = input.float(2.0, "BB Mult",       group=grp2, step=0.1)
kcLen   = input.int(20,    "KC Length",     group=grp2)
kcMult  = input.float(1.5, "KC Mult",       group=grp2, step=0.1)

grp3 = "RSI"
rsiLen  = input.int(14,    "RSI Length",    group=grp3)
rsiBull = input.int(50,    "Bull ≥",        group=grp3)
rsiBear = input.int(50,    "Bear ≤",        group=grp3)

grp4 = "Risk"
atrLen  = input.int(14,    "ATR Length",    group=grp4)
slMult  = input.float(1.5, "SL × ATR",     group=grp4, step=0.1)
tpMult  = input.float(3.0, "TP × ATR",     group=grp4, step=0.1)

grp5 = "Filters"
useVolume  = input.bool(true,  "Volume Filter",        group=grp5)
volMult    = input.float(1.2,  "Volume Spike ×",       group=grp5, step=0.1)
useSession = input.bool(true,  "Active Hours Only",    group=grp5)

// ── Supertrend ───────────────────────────────────────────────
[stVal, stDir] = ta.supertrend(stMult, stLen)
stBull = stDir < 0   // price above supertrend = bullish
stBear = stDir > 0

// ── Bollinger Squeeze ────────────────────────────────────────
// Squeeze = BB inside KC → low volatility coiling → breakout incoming
basis = ta.sma(close, bbLen)
dev   = bbMult * ta.stdev(close, bbLen)
bbUpper = basis + dev
bbLower = basis - dev

kcBasis = ta.ema(close, kcLen)
kcRange = ta.atr(kcLen) * kcMult
kcUpper = kcBasis + kcRange
kcLower = kcBasis - kcRange

squeeze    = bbLower > kcLower and bbUpper < kcUpper   // in squeeze
sqzRelease = not squeeze and squeeze[1]                  // squeeze just released

// Momentum direction in squeeze (LazyBear style)
delta = ta.linreg(close - math.avg(math.avg(ta.highest(high, kcLen), ta.lowest(low, kcLen)), ta.sma(close, kcLen)), kcLen, 0)
momUp   = delta > 0 and delta > delta[1]
momDown = delta < 0 and delta < delta[1]

// ── RSI ──────────────────────────────────────────────────────
rsi = ta.rsi(close, rsiLen)

// ── VWAP ─────────────────────────────────────────────────────
[_, _, vwap] = ta.vwap(hlc3)

// ── Volume ───────────────────────────────────────────────────
vol20    = ta.sma(volume, 20)
volSpike = not useVolume or volume > vol20 * volMult

// ── ATR for risk levels ───────────────────────────────────────
atr = ta.atr(atrLen)

// ── Session: BTC most active = Asian open + US session ────────
// London: 13:30–21:30 IST | NY: 18:30–02:30 IST | Asia: 05:30–10:00 IST
h = hour * 60 + minute
activeHours = not useSession or
  (h >= 330 and h <= 600) or   // Asia open
  (h >= 810 and h <= 1290) or  // London
  (h >= 1110 and h <= 1470)    // NY

// ── Entry Conditions ─────────────────────────────────────────
// BUY: supertrend bull + squeeze release with upward momentum + RSI > 50 + above VWAP
longEntry  = stBull and sqzRelease and momUp   and rsi >= rsiBull and close > vwap and volSpike and activeHours
shortEntry = stBear and sqzRelease and momDown and rsi <= rsiBear and close < vwap and volSpike and activeHours

// Also catch mid-trend continuation (no squeeze needed — strong momentum only)
longCont   = stBull and not squeeze and momUp   and ta.crossover(delta, 0)  and close > vwap and volSpike
shortCont  = stBear and not squeeze and momDown and ta.crossunder(delta, 0) and close < vwap and volSpike

longSignal  = longEntry  or longCont
shortSignal = shortEntry or shortCont

// ── Risk Levels ──────────────────────────────────────────────
longSL  = close - atr * slMult
longTP  = close + atr * tpMult
shortSL = close + atr * slMult
shortTP = close - atr * tpMult

// ── Strategy ─────────────────────────────────────────────────
if longSignal  and strategy.position_size <= 0
    strategy.entry("LONG",  strategy.long)
    strategy.exit("LONG_XT",  "LONG",  stop=longSL,  limit=longTP)

if shortSignal and strategy.position_size >= 0
    strategy.entry("SHORT", strategy.short)
    strategy.exit("SHORT_XT", "SHORT", stop=shortSL, limit=shortTP)

// ── Alerts → WhatsApp ─────────────────────────────────────────
alertcondition(longSignal, title="BTC BUY Signal",
  message='{"symbol":"BTCUSD","action":"BUY","price":{{close}},"sl":' +
    str.tostring(math.round(close - atr * slMult, 0)) +
    ',"tp":' + str.tostring(math.round(close + atr * tpMult, 0)) +
    ',"reason":"Supertrend Bull + Squeeze Release + RSI ' +
    str.tostring(math.round(rsi, 1)) + ' + Above VWAP' +
    (sqzRelease ? " (Squeeze Breakout!)" : " (Continuation)") +
    '","strategy":"BTC_SCALP_PRO","interval":"{{interval}}"}')

alertcondition(shortSignal, title="BTC SELL Signal",
  message='{"symbol":"BTCUSD","action":"SELL","price":{{close}},"sl":' +
    str.tostring(math.round(close + atr * slMult, 0)) +
    ',"tp":' + str.tostring(math.round(close - atr * tpMult, 0)) +
    ',"reason":"Supertrend Bear + Squeeze Release + RSI ' +
    str.tostring(math.round(rsi, 1)) + ' + Below VWAP' +
    (sqzRelease ? " (Squeeze Breakout!)" : " (Continuation)") +
    '","strategy":"BTC_SCALP_PRO","interval":"{{interval}}"}')

// ── Visuals ──────────────────────────────────────────────────
// Supertrend line
stPlot = plot(stVal, "Supertrend",
  color = stBull ? color.new(color.lime, 20) : color.new(color.red, 20),
  linewidth=2)

// VWAP
plot(vwap, "VWAP", color=color.new(color.purple, 0), linewidth=2, style=plot.style_stepline)

// BB
bbUpperPlot = plot(bbUpper, "BB Upper", color=color.new(color.blue, 70), linewidth=1)
bbLowerPlot = plot(bbLower, "BB Lower", color=color.new(color.blue, 70), linewidth=1)
fill(bbUpperPlot, bbLowerPlot, color=color.new(color.blue, 95))

// Squeeze dot on zero line (shown in separate pane — add as indicator separately)
// Green dot = no squeeze, Red dot = in squeeze
barcolor(squeeze ? color.new(color.red, 60) : na, title="Squeeze Bar")

// Entry markers with SL/TP
plotshape(longSignal,  "BUY",  shape.labelup,   location.belowbar,
  color=longEntry ? color.lime : color.new(color.lime, 40),
  text=longEntry ? "⚡BUY" : "↑BUY", textcolor=color.black, size=size.normal)

plotshape(shortSignal, "SELL", shape.labeldown, location.abovebar,
  color=shortEntry ? color.red : color.new(color.red, 40),
  text=shortEntry ? "⚡SELL" : "↓SELL", textcolor=color.white, size=size.normal)

// SL & TP crosses on signal bar
plot(longSignal  ? longSL  : na, "Long SL",  color=color.new(color.red,  0), style=plot.style_cross, linewidth=3)
plot(longSignal  ? longTP  : na, "Long TP",  color=color.new(color.lime, 0), style=plot.style_cross, linewidth=3)
plot(shortSignal ? shortSL : na, "Short SL", color=color.new(color.red,  0), style=plot.style_cross, linewidth=3)
plot(shortSignal ? shortTP : na, "Short TP", color=color.new(color.lime, 0), style=plot.style_cross, linewidth=3)

// Background
bgcolor(stBull and not squeeze ? color.new(color.lime, 97) :
        stBear and not squeeze ? color.new(color.red,  97) :
        squeeze                ? color.new(color.gray, 94) : na,
  title="Background")
