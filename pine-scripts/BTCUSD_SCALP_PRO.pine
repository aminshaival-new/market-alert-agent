//@version=6
// ============================================================
// ATLAS PRO — BTCUSD Scalping Strategy v2
// Logic : Supertrend + BB Squeeze Breakout + RSI + VWAP
// Timeframe : 5m or 15m | Asset: BTCUSD
// Alert : Sends JSON to Railway bot → WhatsApp + Chart
// ============================================================
strategy("ATLAS PRO · BTCUSD Scalp", shorttitle="ATLAS·BTC",
  overlay=true, margin_long=100, margin_short=100,
  default_qty_type=strategy.percent_of_equity, default_qty_value=1,
  initial_capital=10000, commission_type=strategy.commission.percent,
  commission_value=0.05, slippage=10)

// ── Inputs ───────────────────────────────────────────────────
grp1 = "Supertrend"
stMult  = input.float(2.0, "ST Multiplier", step=0.1, group=grp1)
stLen   = input.int(10,    "ST ATR Length", minval=1, group=grp1)

grp2 = "BB Squeeze"
bbLen   = input.int(20,    "BB Length",  minval=1,  group=grp2)
bbMult  = input.float(2.0, "BB Mult",   step=0.1,  group=grp2)
kcLen   = input.int(20,    "KC Length",  minval=1,  group=grp2)
kcMult  = input.float(1.5, "KC Mult",   step=0.1,  group=grp2)

grp3 = "RSI"
rsiLen  = input.int(14,    "RSI Length", minval=1,  group=grp3)
rsiBull = input.int(50,    "Bull ≥",                group=grp3)
rsiBear = input.int(50,    "Bear ≤",                group=grp3)

grp4 = "Risk"
atrLen  = input.int(14,    "ATR Length", minval=1,  group=grp4)
slMult  = input.float(1.5, "SL × ATR", step=0.1,  group=grp4)
tpMult  = input.float(3.0, "TP × ATR", step=0.1,  group=grp4)

grp5 = "Filters"
useVol  = input.bool(true,  "Volume Filter",     group=grp5)
volMult = input.float(1.2,  "Volume Spike ×", step=0.1, group=grp5)
useSess = input.bool(true,  "Active Hours Only", group=grp5)

// ── Supertrend ───────────────────────────────────────────────
[stVal, stDir] = ta.supertrend(stMult, stLen)
stBull = stDir < 0
stBear = stDir > 0

// ── Bollinger Bands ───────────────────────────────────────────
bbBasis = ta.sma(close, bbLen)
bbDev   = bbMult * ta.stdev(close, bbLen)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// ── Keltner Channels (for squeeze detection) ─────────────────
kcBasis = ta.ema(close, kcLen)
kcRange = ta.atr(kcLen) * kcMult
kcUpper = kcBasis + kcRange
kcLower = kcBasis - kcRange

// Squeeze: BB inside KC = low volatility coiling
squeeze    = bbLower > kcLower and bbUpper < kcUpper
sqzRelease = not squeeze and squeeze[1]

// Momentum oscillator (LazyBear squeeze momentum style)
highestHigh = ta.highest(high, kcLen)
lowestLow   = ta.lowest(low, kcLen)
midAvg      = math.avg(math.avg(highestHigh, lowestLow), ta.sma(close, kcLen))
delta       = ta.linreg(close - midAvg, kcLen, 0)
momUp       = delta > 0 and delta > delta[1]
momDown     = delta < 0 and delta < delta[1]

// ── RSI & VWAP ────────────────────────────────────────────────
rsi  = ta.rsi(close, rsiLen)
vwap = ta.vwap(hlc3)
atr  = ta.atr(atrLen)

// ── Volume ────────────────────────────────────────────────────
vol20    = ta.sma(volume, 20)
volSpike = not useVol or volume > vol20 * volMult

// ── Session (BTC: Asia + London + NY) ─────────────────────────
asiaOpen   = time(timeframe.period, "0000-0800", "UTC")
londonOpen = time(timeframe.period, "0700-1600", "UTC")
nyOpen     = time(timeframe.period, "1300-2200", "UTC")
inSession  = not useSess or (not na(asiaOpen) or not na(londonOpen) or not na(nyOpen))

// ── Entry Conditions ─────────────────────────────────────────
longBreak  = stBull and sqzRelease and momUp   and rsi >= rsiBull and close > vwap and volSpike and inSession
shortBreak = stBear and sqzRelease and momDown and rsi <= rsiBear and close < vwap and volSpike and inSession

longCont   = stBull and not squeeze and momUp   and ta.crossover(delta, 0)  and close > vwap and volSpike and inSession
shortCont  = stBear and not squeeze and momDown and ta.crossunder(delta, 0) and close < vwap and volSpike and inSession

longSignal  = longBreak  or longCont
shortSignal = shortBreak or shortCont

// ── Risk Levels ──────────────────────────────────────────────
longSL  = close - atr * slMult
longTP  = close + atr * tpMult
shortSL = close + atr * slMult
shortTP = close - atr * tpMult

// ── Strategy Execution ───────────────────────────────────────
if longSignal and strategy.position_size <= 0
    strategy.entry("LONG", strategy.long)
    strategy.exit("LONG_XT", "LONG", stop=longSL, limit=longTP)
    reason = sqzRelease ? "Supertrend Bull + Squeeze Breakout + RSI " + str.tostring(math.round(rsi, 1)) : "Supertrend Bull + Momentum Continuation + RSI " + str.tostring(math.round(rsi, 1))
    alertMsg = '{"symbol":"BTCUSD","action":"BUY","price":' + str.tostring(math.round(close, 0)) + ',"sl":' + str.tostring(math.round(longSL, 0)) + ',"tp":' + str.tostring(math.round(longTP, 0)) + ',"reason":"' + reason + '","strategy":"BTC_SCALP_PRO","interval":"' + timeframe.period + '"}'
    alert(alertMsg, alert.freq_once_per_bar_close)

if shortSignal and strategy.position_size >= 0
    strategy.entry("SHORT", strategy.short)
    strategy.exit("SHORT_XT", "SHORT", stop=shortSL, limit=shortTP)
    reason = sqzRelease ? "Supertrend Bear + Squeeze Breakout + RSI " + str.tostring(math.round(rsi, 1)) : "Supertrend Bear + Momentum Continuation + RSI " + str.tostring(math.round(rsi, 1))
    alertMsg = '{"symbol":"BTCUSD","action":"SELL","price":' + str.tostring(math.round(close, 0)) + ',"sl":' + str.tostring(math.round(shortSL, 0)) + ',"tp":' + str.tostring(math.round(shortTP, 0)) + ',"reason":"' + reason + '","strategy":"BTC_SCALP_PRO","interval":"' + timeframe.period + '"}'
    alert(alertMsg, alert.freq_once_per_bar_close)

// ── Visuals ──────────────────────────────────────────────────
// Supertrend line
plot(stVal, "Supertrend",
  color=stBull ? color.new(color.lime, 20) : color.new(color.red, 20),
  linewidth=2)

// VWAP
plot(vwap, "VWAP", color=color.new(color.purple, 0), linewidth=2, style=plot.style_stepline)

// Bollinger Bands
bbUp = plot(bbUpper, "BB Upper", color=color.new(color.blue, 70), linewidth=1)
bbLo = plot(bbLower, "BB Lower", color=color.new(color.blue, 70), linewidth=1)
fill(bbUp, bbLo, color=color.new(color.blue, 93))

// Squeeze indicator: red bars = in squeeze, normal = free
barcolor(squeeze ? color.new(color.gray, 40) : na, title="Squeeze")

// Entry labels
plotshape(longSignal,  "BUY",  shape.labelup,   location.belowbar,
  color=longBreak ? color.lime : color.new(color.lime, 50),
  text=longBreak ? "⚡BUY" : "↑BUY", textcolor=color.black, size=size.normal)

plotshape(shortSignal, "SELL", shape.labeldown, location.abovebar,
  color=shortBreak ? color.red : color.new(color.red, 50),
  text=shortBreak ? "⚡SELL" : "↓SELL", textcolor=color.white, size=size.normal)

// SL & TP markers
plot(longSignal  ? longSL  : na, "Long SL",  color=color.new(color.red,  0), style=plot.style_cross, linewidth=3)
plot(longSignal  ? longTP  : na, "Long TP",  color=color.new(color.lime, 0), style=plot.style_cross, linewidth=3)
plot(shortSignal ? shortSL : na, "Short SL", color=color.new(color.red,  0), style=plot.style_cross, linewidth=3)
plot(shortSignal ? shortTP : na, "Short TP", color=color.new(color.lime, 0), style=plot.style_cross, linewidth=3)

// Background
bgcolor(stBull and not squeeze ? color.new(color.lime, 96) :
        stBear and not squeeze ? color.new(color.red,  96) :
        squeeze                ? color.new(color.gray, 93) : na,
  title="Background")
